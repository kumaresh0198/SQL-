1. Create a table with employee details and display the details of employee name starts with letter 'B' also the salary should be above 20000.
use students;
show tables;

create table employee_details(
emp_id tinyint primary key,
emp_name varchar(30) not null,
emp_salary int check (emp_salary > 0),
emp_depart varchar(15)
);

