2. Create a product table. Display  product details with price in ascending order and the product price should be below 1000 or product category as kids.
create table product(
product_id int primary key,
product_category varchar(25) not null,
product_price int not null
);

insert into product(product_id, product_category, product_price) values
(001, 'adult', 350),
(002, 'kids', 550),
(003, 'new born', 750),
(004, 'new born', 1200),
(005, 'adult', 100),
(006, 'kids', 1350);

select * from product where product_price < 1000 or product_category = 'kids' order by product_price;

